#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <path-to-production-cycle>" >&2
    exit 1
fi

cycle="$(realpath "$1")"

if [[ ! -d "$cycle/generated" ]]; then
    echo "Error: '$cycle/generated' is not a directory" >&2
    exit 1
fi

mkdir -p "$cycle/tarballs"

output="$cycle/tarballs/$(basename "$cycle")-plots.tar.xz"
echo "Archiving into $output..."

cd "$cycle/generated"

plots_list="$(mktemp)"
trap 'rm -f "$plots_list"' EXIT

find . -type d -name plots -print0 > "$plots_list"

if [[ ! -s "$plots_list" ]]; then
    echo "Error: no 'plots' directories found under '$cycle/generated'; not creating archive." >&2
    exit 1
fi

tar --xz --verbose --create \
    --file "$output" \
    --transform "s|^\./||;s|^|$(basename "$cycle")-plots/|" \
    --null --files-from "$plots_list"

echo "Done!"
